# OS / IDE
.DS_Store
.vscode/
.idea/

# Data
# Ignore all data/ contents by default, then re-include data/raw/items/ for
# the committed scrape outputs. Large/regenerated subdirs stay ignored.
**/data/
!**/data/
**/data/processed/
**/data/models/
# data/reference/: ignore contents EXCEPT the tiny committed lookup.csv (the
# publisher's options.json source — needed on a clean checkout, ~5 KB).
**/data/reference/*
!**/data/reference/lookup.csv
**/data/raw/kaggle/
# Per-tick checkpoints (data/ticks/<YYYY-MM>/): ignore the heavy/regenerable
# artifacts, keep the lightweight ones tracked (predictions_*.parquet, _SUCCESS,
# manifest.json) so a clean checkout has a seed checkpoint. published/ is the
# immutable per-tick archive (goes to GCS) — local only, redundant with the
# committed frontend/data/ "latest" copy the SPA fetches.
**/data/ticks/*/merged_*.parquet
**/data/ticks/*/training_*.parquet
**/data/ticks/*/training_run.json
**/data/ticks/*/model/
**/data/ticks/*/published/
# Published static JSON (pipelines.monthly.publish output). Commit the canonical
# files the SPA fetches (turnkey demo, like committed predictions); the versioned
# *_<YYYY-MM>.json archives are regenerated each tick.
**/frontend/data/*_[0-9][0-9][0-9][0-9]-[0-9][0-9].json
.env

# MLflow
**/mlflow.db
**/mlruns/

# Claude
.claude